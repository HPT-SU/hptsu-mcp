HPTSU_API_KEY=
HPTSU_BASE_URL=https://hpt.su/api/v1
HPTSU_TRANSPORT=stdio
HPTSU_LOG_LEVEL=INFO

# Hosted streamable-http only (mcp.hpt.su).
HPTSU_HOST=127.0.0.1
HPTSU_PORT=8000
# Comma-separated list of allowed Host: header values for DNS-rebind
# protection. Required for hosted instances behind nginx, e.g.:
# HPTSU_ALLOWED_HOSTS=mcp.hpt.su,mcp.hpt.su:*
HPTSU_ALLOWED_HOSTS=
